  {from:'statistical_inference', to:'hypothesis_testing', type:'PREREQUISITE_OF'},
  {from:'statistical_inference', to:'regression', type:'PREREQUISITE_OF'},

  {from:'logic', to:'logic_discrete', type:'PREREQUISITE_OF'},
  {from:'sets', to:'set_theory', type:'PREREQUISITE_OF'},
  {from:'logic_discrete', to:'discrete_math', type:'PART_OF'},
  {from:'set_theory', to:'discrete_math', type:'PART_OF'},
  {from:'discrete_math', to:'graph_theory', type:'PART_OF'},
  {from:'permutation_combination', to:'combinatorics', type:'PREREQUISITE_OF'},
  {from:'combinatorics', to:'graph_theory', type:'RELATED_TO'},
  {from:'integers', to:'number_theory', type:'PREREQUISITE_OF'},
  {from:'sets', to:'abstract_algebra', type:'PREREQUISITE_OF'},
  {from:'abstract_algebra', to:'groups', type:'PART_OF'},
  {from:'groups', to:'rings_fields', type:'PREREQUISITE_OF'},
  {from:'limits', to:'real_analysis', type:'PREREQUISITE_OF'},
  {from:'real_numbers', to:'real_analysis', type:'PREREQUISITE_OF'},
  {from:'real_analysis', to:'metric_spaces', type:'PREREQUISITE_OF'},
  {from:'metric_spaces', to:'topology', type:'PREREQUISITE_OF'},
  {from:'derivative', to:'optimization', type:'PREREQUISITE_OF'},
  {from:'gradient', to:'optimization', type:'PREREQUISITE_OF'},
  {from:'linear_algebra', to:'optimization', type:'RELATED_TO'},
  {from:'calculus', to:'numerical_methods', type:'RELATED_TO'},
  {from:'matrix', to:'numerical_methods', type:'PREREQUISITE_OF'},
  {from:'calculus', to:'university_math', type:'PART_OF'},
  {from:'linear_algebra', to:'university_math', type:'PART_OF'},
  {from:'probability_theory', to:'university_math', type:'PART_OF'},
  {from:'statistical_inference', to:'university_math', type:'PART_OF'},
  {from:'discrete_math', to:'university_math', type:'PART_OF'},
  {from:'abstract_algebra', to:'university_math', type:'PART_OF'},
  {from:'real_analysis', to:'university_math', type:'PART_OF'},
  {from:'topology', to:'university_math', type:'PART_OF'},
  {from:'optimization', to:'university_math', type:'PART_OF'},
  {from:'limits', to:'calculus', type:'PART_OF'},
  {from:'continuity', to:'calculus', type:'PART_OF'},
  {from:'derivative', to:'calculus', type:'PART_OF'},
  {from:'integral', to:'calculus', type:'PART_OF'},
  {from:'series', to:'calculus', type:'PART_OF'},
  {from:'multivariable_functions', to:'calculus', type:'PART_OF'},
  {from:'differential_equations', to:'calculus', type:'PART_OF'},
  {from:'matrix', to:'linear_algebra', type:'PART_OF'},
  {from:'linear_systems', to:'linear_algebra', type:'PART_OF'},
  {from:'determinant', to:'linear_algebra', type:'PART_OF'},
  {from:'vector_space', to:'linear_algebra', type:'PART_OF'},
  {from:'linear_transformations', to:'linear_algebra', type:'PART_OF'},
  {from:'eigenvalues', to:'linear_algebra', type:'PART_OF'}
] AS rel
MATCH (a:Concept {id: rel.from})
MATCH (b:Concept {id: rel.to})
FOREACH (_ IN CASE WHEN rel.type = 'PREREQUISITE_OF' THEN [1] ELSE [] END |
  MERGE (a)-[:PREREQUISITE_OF]->(b)
)
FOREACH (_ IN CASE WHEN rel.type = 'PART_OF' THEN [1] ELSE [] END |
  MERGE (a)-[:PART_OF]->(b)
)
FOREACH (_ IN CASE WHEN rel.type = 'RELATED_TO' THEN [1] ELSE [] END |
  MERGE (a)-[:RELATED_TO]->(b)
)
RETURN count(rel) AS relationships_loaded;
